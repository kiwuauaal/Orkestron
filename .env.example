# OpenAI API Key (get free tier at https://platform.openai.com)
OPENAI_API_KEY=your-api-key-here

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379

# RabbitMQ Configuration
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=admin
RABBITMQ_PASS=admin

# Application Settings
LOG_LEVEL=INFO
ENVIRONMENT=development
